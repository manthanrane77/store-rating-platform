{
  "name": "store-rating-platform",
  "version": "1.0.0",
  "description": "Full-stack store rating platform - Express + MySQL + React",
  "scripts": {
    "start": "node backend/src/index.js",
    "dev": "nodemon backend/src/index.js",
    "frontend": "npm start --prefix frontend",
    "install:all": "npm install && npm install --prefix frontend",
    "db:setup": "mysql -u root -p < database/schema.sql"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-validator": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "mysql2": "^3.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.0"
  }
}
